{
  "name": "iptv-astro",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "prebuild": "astro check && node scripts/build-og-images.mjs",
    "preview": "astro preview",
    "lint": "eslint src/",
    "format": "prettier --write \"**/*.{astro,ts,js,mjs,css,json,md}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{astro,ts,js,mjs,css,json,md}\" --ignore-path .prettierignore",
    "typecheck": "astro check"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/sitemap": "^3.4.0",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/noto-naskh-arabic": "^5.2.11",
    "@playform/compress": "0.2.3",
    "@tailwindcss/vite": "^4.1.6",
    "astro": "^5.7.0",
    "sharp": "^0.35.1",
    "tailwindcss": "^4.1.6",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^22.15.0",
    "eslint": "^10.6.0",
    "eslint-plugin-astro": "^1.7.0",
    "prettier": "^3.9.1",
    "prettier-plugin-astro": "^0.14.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "typescript-eslint": "^8.62.0"
  },
  "allowScripts": {
    "sharp@0.35.1": true
  }
}
