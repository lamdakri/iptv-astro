---
import { LANGUAGES, getLangFromUrl } from '../i18n/ui';

const currentLang = getLangFromUrl(Astro.url);
const currentPath = Astro.url.pathname.replace(/^\/[a-z]{2}\/?/, '/');
const langData = Object.keys(LANGUAGES).map((code) => ({
  code,
  flag: LANGUAGES[code as keyof typeof LANGUAGES].flag,
  label: LANGUAGES[code as keyof typeof LANGUAGES].label,
}));
---

<div id="lang-banner" style="display:none;" class="bg-gradient-to-r from-brand-900/95 to-surface-900/95 backdrop-blur-md border-b border-brand-500/20 shadow-lg shadow-brand-500/5">
  <div class="container-custom flex items-center justify-between gap-3 py-2.5">
    <div class="flex items-center gap-2 text-sm text-surface-200">
      <span id="lang-banner-flag" class="text-lg"></span>
      <span id="lang-banner-text"></span>
    </div>
    <div class="flex items-center gap-2 flex-shrink-0">
      <a id="lang-banner-link" href="#" class="btn-primary text-xs px-4 py-1.5 rounded-lg" data-track="lang_switch" data-track-category="engagement">
        <span id="lang-banner-btn"></span>
      </a>
      <button id="lang-banner-dismiss" class="text-surface-400 hover:text-white p-1.5 transition-colors" aria-label="Dismiss">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>
</div>

<script define:vars={{ currentLang, currentPath, langData }}>
  (function() {
    const banner = document.getElementById('lang-banner');
    const flagEl = document.getElementById('lang-banner-flag');
    const textEl = document.getElementById('lang-banner-text');
    const linkEl = document.getElementById('lang-banner-link');
    const btnEl = document.getElementById('lang-banner-btn');
    const dismissBtn = document.getElementById('lang-banner-dismiss');

    if (!banner) return;

    // Check if user already dismissed
    if (localStorage.getItem('lang-banner-dismissed')) return;

    const supported = { en: true, fr: true, ar: true, es: true, de: true, it: true, pt: true };
    const navLang = (navigator.language || navigator.languages?.[0] || 'en').split('-')[0];

    // Don't show if already on the detected language, or if detected language isn't supported, or if it's English (default)
    if (navLang === currentLang || !supported[navLang] || navLang === 'en') return;

    const detected = langData.find(l => l.code === navLang);
    if (!detected) return;

    // Build banner text
    const messages = {
      en: { text: 'We also speak ' + detected.label + '! Switch to ' + detected.label + '?', btn: 'Switch to ' + detected.label },
      fr: { text: 'Nous parlons aussi ' + detected.label + ' ! Passer en ' + detected.label + ' ?', btn: 'Passer en ' + detected.label },
      ar: { text: 'نتحدث أيضاً ' + detected.label + '! التبديل إلى ' + detected.label + '؟', btn: 'التبديل إلى ' + detected.label },
      es: { text: '¡También hablamos ' + detected.label + '! ¿Cambiar a ' + detected.label + '?', btn: 'Cambiar a ' + detected.label },
      de: { text: 'Wir sprechen auch ' + detected.label + '! Zu ' + detected.label + ' wechseln?', btn: 'Zu ' + detected.label },
      it: { text: 'Parliamo anche ' + detected.label + '! Passare a ' + detected.label + '?', btn: 'Passa a ' + detected.label },
      pt: { text: 'Tambem falamos ' + detected.label + '! Mudar para ' + detected.label + '?', btn: 'Mudar para ' + detected.label },
    };

    const msg = messages[currentLang] || messages.en;
    flagEl.textContent = detected.flag;
    textEl.textContent = msg.text;
    btnEl.textContent = msg.btn;
    linkEl.href = '/' + detected.code + currentPath;

    // Show banner
    banner.style.display = 'block';

    // Dismiss handler
    dismissBtn.addEventListener('click', function() {
      localStorage.setItem('lang-banner-dismissed', '1');
      banner.style.display = 'none';
    });
  })();
</script>
