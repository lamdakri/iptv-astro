---
import { getCollection, getEntry } from 'astro:content';
import { getLangFromUrl, useTranslations, LANGUAGES } from '../../i18n/ui';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQ from '../../components/FAQ.astro';
import SchemaMarkup from '../../components/SchemaMarkup.astro';
import { WHATSAPP_NUMBER as WA } from '../../i18n/whatsapp';

export async function getStaticPaths() {
  const seoPages = await getCollection('seoPages');
  const params: Array<{ params: { lang: string; keyword: string } }> = [];
  for (const page of seoPages) {
    for (const lang of Object.keys(page.data.languages)) {
      if (page.data.languages[lang as keyof typeof page.data.languages]) {
        params.push({ params: { lang, keyword: page.data.slug } });
      }
    }
  }
  return params;
}

const { lang, keyword } = Astro.params;
const t = useTranslations(lang);

const seoCollection = await getCollection('seoPages');
const seoEntry = seoCollection.find((p) => p.data.slug === keyword);

if (!seoEntry) {
  return Astro.redirect('/' + lang + '/', 301);
}

const seoData = seoEntry.data.languages[lang as keyof typeof seoEntry.data.languages];

if (!seoData) {
  return Astro.redirect('/' + lang + '/', 301);
}

const faqItems = (seoData.faqs || []).map((f: { question: string; answer: string }) => ({
  question: f.question,
  answer: f.answer,
}));

const pageTitle = seoData.title;
const pageUrl = Astro.url.href;

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: pageTitle,
  description: seoData.description,
  url: pageUrl,
  inLanguage: lang,
  isPartOf: {
    '@type': 'WebSite',
    name: t('site.name'),
    url: Astro.site?.href || 'https://iptv4kworld.com',
  },
};
---

<BaseLayout title={pageTitle} description={seoData.description} keywords={seoData.h1 + ', IPTV, IPTV subscription'} schema={webPageSchema}>
  <SchemaMarkup type="faq" data={{ questions: faqItems }} />

  <section class="pt-32 pb-20">
    <div class="container-custom max-w-4xl">
      <Breadcrumb items={[
        { label: t('breadcrumb.home'), href: '/' + lang + '/' },
        { label: seoData.h1 },
      ]} />

      <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-6 reveal">{seoData.h1}</h1>
      <p class="text-surface-400 text-lg mb-12 reveal" data-reveal-delay="100">{seoData.description}</p>

      <div class="prose prose-invert prose-lg max-w-none mb-8 reveal" data-reveal-delay="150">
        <div set:html={seoData.content} />
      </div>

      {seoData.h2s && seoData.h2s.length > 0 && seoData.h2s.map((h2: string) => (
        <h2 class="text-2xl font-bold text-white mt-12 mb-4">{h2}</h2>
      ))}

      <div class="mt-12 p-8 rounded-2xl bg-gradient-to-r from-brand-900/30 to-surface-900 border border-surface-800 text-center reveal">
        <h2 class="text-2xl font-bold text-white mb-3">{t('seo.cta.title')}</h2>
        <p class="text-surface-400 mb-6">{t('seo.cta.subtitle', { keyword: seoData.h1 })}</p>
        <a
          href={`https://wa.me/${WA}?text=${encodeURIComponent('Hello! I want a free IPTV trial.')}`}
          class="btn-whatsapp"
          target="_blank" rel="noopener noreferrer"
          data-track="whatsapp_click"
          data-track-label="SEO CTA"
          data-track-value={seoData.h1}
          data-track-category="conversion"
        >
          {t('seo.cta.button')}
        </a>
      </div>

      {seoData.internalLinks && seoData.internalLinks.length > 0 && (
        <div class="mt-12">
          <h3 class="text-xl font-bold text-white mb-4">Related Pages</h3>
          <ul class="space-y-2">
            {seoData.internalLinks.map((link: { text: string; url: string }) => (
              <li><a href={link.url} class="text-brand-400 hover:text-brand-300">{link.text}</a></li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </section>

  {faqItems.length > 0 && <FAQ title={t('faq.title')} subtitle={t('faq.subtitle')} items={faqItems} />}
</BaseLayout>
