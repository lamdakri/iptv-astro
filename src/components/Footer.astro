---
import { getLangFromUrl, useTranslations } from '../i18n/ui';
import { getWhatsAppUrl, getWhatsAppTrialMsg, WHATSAPP_NUMBER } from '../i18n/whatsapp';
import WhatsAppIcon from './icons/WhatsAppIcon.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer class="relative bg-surface-900/50 border-t border-brand-700/10 pt-16 pb-8">
  <!-- Top glow line -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-brand-500/30 to-transparent"></div>

  <div class="container-custom">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 mb-12">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href={`/${lang}/`} class="flex items-center gap-2 mb-4">
          <span class="text-2xl">📡</span>
          <span class="text-xl font-extrabold gradient-text">{t('site.name')}</span>
        </a>
        <p class="text-surface-400 text-sm leading-relaxed">{t('footer.description')}</p>
        <!-- Social proof -->
        <div class="flex items-center gap-3 mt-5">
          <div class="flex -space-x-1">
            <div class="w-8 h-8 rounded-full bg-brand-600 flex items-center justify-center text-xs font-bold text-white border-2 border-surface-900">K</div>
            <div class="w-8 h-8 rounded-full bg-cyan-500 flex items-center justify-center text-xs font-bold text-white border-2 border-surface-900">S</div>
            <div class="w-8 h-8 rounded-full bg-whatsapp flex items-center justify-center text-xs font-bold text-white border-2 border-surface-900">A</div>
          </div>
          <span class="text-sm text-surface-400">{t('footer.happyCustomers')}</span>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">{t('footer.menuHeading')}</h4>
        <ul class="space-y-2.5">
          <li><a href={`/${lang}/`} class="text-surface-400 text-sm hover:text-brand-400 transition-colors" data-track="nav_click" data-track-label="Footer Home">{t('nav.home')}</a></li>
          <li><a href={`/${lang}/pricing/`} class="text-surface-400 text-sm hover:text-brand-400 transition-colors" data-track="nav_click" data-track-label="Footer Pricing">{t('nav.pricing')}</a></li>
          <li><a href={`/${lang}/blog/`} class="text-surface-400 text-sm hover:text-brand-400 transition-colors" data-track="nav_click" data-track-label="Footer Blog">{t('nav.blog')}</a></li>
        </ul>
      </div>

      <!-- Support -->
      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">{t('footer.supportHeading')}</h4>
        <ul class="space-y-2.5">
          <li>
            <a href={getWhatsAppUrl('')} class="flex items-center gap-2 text-surface-400 text-sm hover:text-whatsapp transition-colors group" target="_blank" rel="noopener noreferrer" data-track="whatsapp_click" data-track-label="Footer Support" data-track-category="conversion">
              <WhatsAppIcon class="h-4 w-4 text-whatsapp" />
              {t('footer.whatsapp')}
            </a>
          </li>
          <li><a href={`/${lang}/pricing/`} class="text-surface-400 text-sm hover:text-brand-400 transition-colors" data-track="nav_click" data-track-label="Footer Trial Link">{t('cta.trial.short')}</a></li>
        </ul>
      </div>

      <!-- CTA -->
      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">{t('footer.getStartedHeading')}</h4>
        <p class="text-surface-400 text-sm mb-4">{t('footer.ctaText')}</p>
        <a
          href={getWhatsAppUrl(getWhatsAppTrialMsg(t))}
          class="btn-whatsapp text-sm px-5 py-2.5"
          target="_blank"
          rel="noopener noreferrer"
          data-track="whatsapp_click"
          data-track-label="Footer Trial CTA"
          data-track-category="conversion"
        >
          {t('cta.trial.short')}
        </a>
      </div>
    </div>

    <!-- Newsletter -->
    <div class="border-t border-surface-800/50 pt-8 mb-8">
      <div class="max-w-md mx-auto text-center">
        <span class="section-eyebrow mx-auto justify-center text-xs">{t('newsletter.eyebrow')}</span>
        <h4 class="text-lg font-bold text-white mb-2">{t('newsletter.title')}</h4>
        <p class="text-surface-400 text-sm mb-5">{t('newsletter.subtitle')}</p>
        <form id="newsletter-form" class="flex flex-col sm:flex-row gap-2"
          data-wa-number={WHATSAPP_NUMBER}
          data-wa-message={t('whatsapp.newsletter')}>
          <label for="newsletter-email" class="sr-only">{t('newsletter.placeholder')}</label>
          <input type="email" id="newsletter-email" placeholder={t('newsletter.placeholder')} required
            class="flex-1 px-4 py-3 rounded-lg bg-surface-800/60 border border-surface-700/40 text-white text-sm placeholder:text-surface-500 focus:outline-none focus:border-brand-500/50 transition-colors" />
          <button type="submit" id="newsletter-btn"
            class="btn-primary text-sm px-5 py-3 whitespace-nowrap">
            {t('newsletter.button')}
          </button>
        </form>
        <p id="newsletter-msg" class="text-green-400 text-sm mt-3 hidden">{t('newsletter.success')}</p>
        <p class="text-surface-500 text-xs mt-3">{t('newsletter.disclaimer')}</p>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-surface-800/50 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-surface-500">
      <p>&copy; {new Date().getFullYear()} {t('site.name')}. {t('footer.rights')}</p>
      <div class="flex items-center gap-6">
        <a href={`/${lang}/privacy/`} class="hover:text-surface-400 transition-colors">{t('footer.privacy')}</a>
        <a href={`/${lang}/terms/`} class="hover:text-surface-400 transition-colors">{t('footer.terms')}</a>
      </div>
    </div>
  </div>
</footer>

<script>
  (function() {
    const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
    const msg = document.getElementById('newsletter-msg');
    const btn = document.getElementById('newsletter-btn') as HTMLButtonElement | null;
    if (!form || !btn) return;
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      const input = document.getElementById('newsletter-email') as HTMLInputElement | null;
      const email = input?.value?.trim() || '';
      if (!email) return;

      btn.disabled = true;

      const waNumber = form.dataset.waNumber || '212606123321';
      const template = form.dataset.waMessage || 'Hi! I want to subscribe to the IPTV 4K World newsletter. My email is: {email}';
      const waMessage = encodeURIComponent(template.replace('{email}', email));

      window.open('https://wa.me/' + waNumber + '?text=' + waMessage, '_blank');

      if (msg) msg.classList.remove('hidden');
      form.reset();
      btn.disabled = false;
    });
  })();
</script>
