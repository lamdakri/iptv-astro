---
interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  xDefaultUrl?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: string;
  lang?: string;
  alternateLangs?: { lang: string; url: string }[];
  schema?: object;
  robots?: string;
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleAuthor?: string;
  articleTags?: string[];
  articleSection?: string;
  keywords?: string;
}

const {
  title,
  description,
  canonicalURL = '',
  xDefaultUrl = '',
  ogImage = '/images/og-default.png',
  ogImageAlt = '',
  ogType = 'website',
  lang = 'en',
  alternateLangs = [],
  schema,
  robots,
  articlePublishedTime,
  articleModifiedTime,
  articleAuthor,
  articleTags = [],
  articleSection,
  keywords,
} = Astro.props;

const localeMap: Record<string, string> = {
  en: 'en_US',
  fr: 'fr_FR',
  ar: 'ar_SA',
  es: 'es_ES',
  de: 'de_DE',
  it: 'it_IT',
  pt: 'pt_PT',
};
const ogLocale = localeMap[lang] || 'en_US';

// Language-specific OG images for localized social sharing
const ogImageMap: Record<string, string> = {
  en: '/images/og-default.png',
  fr: '/images/og-fr.png',
  ar: '/images/og-ar.png',
  es: '/images/og-es.png',
  de: '/images/og-de.png',
  it: '/images/og-it.png',
  pt: '/images/og-pt.png',
};
// Use language-specific OG image only when no custom image was explicitly provided
const localizedOgImage = ogImage === '/images/og-default.png'
  ? (ogImageMap[lang] || ogImage)
  : ogImage;
---

<title>{title}</title>
<meta name="description" content={description} />
{keywords && <meta name="keywords" content={keywords} />}
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="canonical" href={canonicalURL || Astro.url.href} />

<!-- Robots -->
<meta name="robots" content={robots} />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL || Astro.url.href} />
<meta property="og:image" content={localizedOgImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:type" content="image/png" />
{ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content="IPTV 4K World" />

<!-- Article-specific OG tags -->
{ogType === 'article' && articlePublishedTime && (
  <meta property="article:published_time" content={articlePublishedTime} />
)}
{ogType === 'article' && articleModifiedTime && articleModifiedTime !== articlePublishedTime && (
  <meta property="article:modified_time" content={articleModifiedTime} />
)}
{ogType === 'article' && articleAuthor && (
  <meta property="article:author" content={articleAuthor} />
)}
{ogType === 'article' && articleTags.map((tag) => (
  <meta property="article:tag" content={tag} />
))}
{ogType === 'article' && articleSection && (
  <meta property="article:section" content={articleSection} />
)}
<meta property="og:locale" content={ogLocale} />
{
  alternateLangs.map(({ lang: altLang }) => {
    const altOgLocale = Object.entries(localeMap).find(([code]) => altLang.startsWith(code))?.[1];
    if (altOgLocale && altOgLocale !== ogLocale) {
      return <meta property="og:locale:alternate" content={altOgLocale} />;
    }
    return null;
  })
}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={localizedOgImage} />

<!-- hreflang -->
<link rel="alternate" hreflang="x-default" href={xDefaultUrl || canonicalURL || Astro.url.href} />
{
  alternateLangs.map(({ lang, url }) => (
    <link rel="alternate" hreflang={lang} href={url} />
  ))
}

<!-- Schema markup -->
{schema && (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline />
)}
