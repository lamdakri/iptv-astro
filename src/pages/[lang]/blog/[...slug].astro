---
import { getCollection, getEntry, type CollectionEntry } from 'astro:content';
import { getLangFromUrl, useTranslations, LANGUAGES } from '../../../i18n/ui';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import BlogCard from '../../../components/BlogCard.astro';
import SchemaMarkup from '../../../components/SchemaMarkup.astro';
import { WHATSAPP_NUMBER as WA } from '../../../i18n/whatsapp';

interface Props {
  entry: CollectionEntry<'blog'>;
}

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((entry) => ({
    params: { lang: entry.data.lang, slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { lang } = Astro.params;
const t = useTranslations(lang);

const relatedPosts = (await getCollection('blog', ({ data }) =>
  !data.draft && data.lang === lang && data.slug !== entry.slug
)).sort((a, b) => b.data.date.getTime() - a.data.date.getTime()).slice(0, 3);

const pageTitle = entry.data.title + ' | ' + t('blog.title') + ' | ' + t('site.name');

const pageUrl = Astro.url.href;
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  '@id': pageUrl + '#article',
  headline: entry.data.title,
  description: entry.data.description,
  image: entry.data.image ? new URL(entry.data.image, Astro.site || 'https://iptv4kworld.com').href : undefined,
  author: { '@type': 'Person', name: entry.data.author },
  publisher: {
    '@type': 'Organization',
    name: 'IPTV 4K World',
    logo: {
      '@type': 'ImageObject',
      url: new URL('/favicon.svg', Astro.site || 'https://iptv4kworld.com').href,
    },
  },
  datePublished: entry.data.date.toISOString(),
  dateModified: (entry.data.updatedDate || entry.data.date).toISOString(),
  mainEntityOfPage: { '@id': pageUrl },
  keywords: entry.data.keywords?.join(', ') || undefined,
};
---

<BaseLayout
  title={pageTitle}
  description={entry.data.description}
  ogImage={entry.data.image}
  ogType="article"
  articlePublishedTime={entry.data.date.toISOString()}
  articleAuthor={entry.data.author}
  articleTags={entry.data.keywords || []}
  articleSection={entry.data.category}
  keywords={entry.data.keywords?.join(', ')}
  schema={articleSchema}
>
  <SchemaMarkup type="faq" />

  {entry.data.howToSteps && entry.data.howToSteps.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'HowTo',
      name: entry.data.title,
      description: entry.data.description,
      step: entry.data.howToSteps.map((step, i) => ({
        '@type': 'HowToStep',
        position: i + 1,
        name: step.name,
        text: step.text,
        ...(step.url && { url: step.url }),
        ...(step.image && { image: step.image }),
      })),
      ...(entry.data.image && { image: {
        '@type': 'ImageObject',
        url: new URL(entry.data.image, Astro.site || 'https://iptv4kworld.com').href,
      }}),
    })}></script>
  )}

  <article class="pt-32 pb-20">
    <div class="container-custom">
      <Breadcrumb items={[
        { label: t('breadcrumb.home'), href: '/' + lang + '/' },
        { label: t('blog.title'), href: '/' + lang + '/blog/' },
        { label: entry.data.title },
      ]} />

      <header class="mb-12 text-center reveal">
        {entry.data.category && (
          <span class="text-xs font-semibold text-brand-400 uppercase tracking-wider">{entry.data.category}</span>
        )}
        <h1 class="text-3xl md:text-5xl font-extrabold text-white mt-4 mb-6">{entry.data.title}</h1>
        <div class="flex items-center justify-center gap-4 text-sm text-surface-500">
          <span>{entry.data.author}</span>
          <span>·</span>
          <time datetime={entry.data.date.toISOString()}>
            {new Date(entry.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </div>
      </header>

      {entry.data.image && (
        <img src={entry.data.image} alt={entry.data.title} width="800" height="400" class="w-full max-h-96 object-cover rounded-2xl mb-12" loading="eager" fetchpriority="high" />
      )}

      <div class="prose prose-invert prose-lg max-w-3xl mx-auto reveal" data-reveal-delay="100">
        <Content />
      </div>

      <!-- CTA -->
      <div class="max-w-2xl mx-auto mt-16 p-8 rounded-2xl bg-gradient-to-r from-brand-900/30 to-surface-900 border border-surface-800 text-center reveal">
        <h3 class="text-2xl font-bold text-white mb-3">{t('cta.final.title')}</h3>
        <p class="text-surface-400 mb-6">{t('cta.final.subtitle')}</p>
        <a
          href={`https://wa.me/${WA}?text=${encodeURIComponent('Hello! I want a free IPTV trial.')}`}
          class="btn-whatsapp"
          target="_blank" rel="noopener noreferrer"
        >
          {t('cta.final.button')}
        </a>
      </div>

      {relatedPosts.length > 0 && (
        <section class="mt-20">
          <h2 class="text-2xl font-bold text-white mb-8">{t('blog.relatedPosts')}</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {relatedPosts.map((post, i) => (
              <div class="reveal reveal-scale" data-reveal-delay={String(i * 120)}>
              <BlogCard
                title={post.data.title}
                description={post.data.description}
                slug={post.slug}
                lang={lang}
                date={post.data.date}
                category={post.data.category}
                image={post.data.image}
              />
              </div>
            ))}
          </div>
        </section>
      )}
    </div>
  </article>
</BaseLayout>
