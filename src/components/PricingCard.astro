---
import { WHATSAPP_NUMBER as WA } from '../i18n/whatsapp';

interface Props {
  name: string;
  price: string;
  period: string;
  originalPrice?: string;
  savings?: string;
  features: string[];
  ctaLabel: string;
  trialLabel: string;
  featured?: boolean;
  popularLabel?: string;
  couponLabel?: string;
  couponPlaceholder?: string;
  couponApply?: string;
  couponApplied?: string;
  couponInvalid?: string;
}

const {
  name,
  price,
  period,
  originalPrice = '',
  savings = '',
  features,
  ctaLabel,
  trialLabel,
  featured = false,
  popularLabel = '',
  couponLabel = '',
  couponPlaceholder = 'Enter code...',
  couponApply = 'Apply',
  couponApplied = 'Applied!',
  couponInvalid = 'Invalid',
} = Astro.props;

const isPromo = originalPrice !== '';
const couponCodes: Record<string, number> = { 'IPTV10': 10, 'WELCOME5': 5, 'FLASH15': 15 };
---

<div class={`pricing-card reveal reveal-scale ${featured ? 'featured' : ''}`} data-reveal-delay={featured ? '200' : '0'}>
  {(isPromo || popularLabel) && (
    <div class="pricing-badges">
      {isPromo && (
        <span class="pricing-badge pricing-badge--sale">{savings}</span>
      )}
      {popularLabel && (
        <span class="pricing-badge">{popularLabel}</span>
      )}
    </div>
  )}
  <div>
    <h3 class="text-xl font-bold text-white">{name}</h3>
    <div class="mt-4 flex items-baseline gap-2 flex-wrap">
      {isPromo && (
        <span class="text-2xl text-surface-500 line-through">€{originalPrice}</span>
      )}
      <span class="text-5xl font-extrabold gradient-text-static" id={`price-${name.replace(/\s/g,'')}`}>€{price}</span>
      <span class="text-surface-400 text-sm">{period}</span>
    </div>
    <!-- Coupon -->
    {couponLabel && (
      <div class="mt-3 p-3 rounded-lg bg-surface-800/40 border border-surface-700/30">
        <p class="text-xs text-surface-400 mb-2">{couponLabel}</p>
        <div class="flex gap-1.5">
          <input type="text" class="coupon-input flex-1 px-3 py-1.5 rounded-md bg-surface-900/60 border border-surface-700/40 text-white text-xs placeholder:text-surface-500 focus:outline-none focus:border-brand-500/40" placeholder={couponPlaceholder} data-plan={name.replace(/\s/g,'')} />
          <button class="coupon-btn px-3 py-1.5 rounded-md bg-brand-600/30 text-brand-300 text-xs font-semibold hover:bg-brand-600/50 transition-colors" data-plan={name.replace(/\s/g,'')} data-codes={JSON.stringify(couponCodes)} data-applied={couponApplied} data-invalid={couponInvalid}>{couponApply}</button>
        </div>
        <p class="coupon-msg text-xs mt-1.5 hidden"></p>
      </div>
    )}
  </div>
  <ul class="space-y-3 flex-1">
    {features.map((f) => (
      <li class="checkmark">{f}</li>
    ))}
  </ul>
  <div class="flex flex-col gap-3 mt-2">
    <a
      href={`https://wa.me/${WA}?text=${encodeURIComponent('Hi! I want the ' + name + ' plan.')}`}
      class={`btn-whatsapp w-full text-base ${featured ? '!bg-gradient-to-r !from-brand-600 !to-brand-500 shadow-brand-500/30' : ''}`}
      target="_blank"
      rel="noopener noreferrer"
      data-track="whatsapp_click"
      data-track-label="Pricing Card"
      data-track-value={name}
      data-track-category="conversion"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 448 512">
        <path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157z"/>
      </svg>
      {ctaLabel}
    </a>
    <a
      href={`https://wa.me/${WA}?text=${encodeURIComponent('Hello! I want a free 12-hour IPTV trial.')}`}
      class="text-center text-sm text-surface-400 hover:text-brand-400 transition-colors font-medium"
      target="_blank"
      rel="noopener noreferrer"
      data-track="whatsapp_click"
      data-track-label="Pricing Trial"
      data-track-value={name}
      data-track-category="conversion"
    >
      {trialLabel}
    </a>
  </div>
</div>

<script>
  document.querySelectorAll('.coupon-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      const plan = btn.dataset.plan;
      const input = document.querySelector('.coupon-input[data-plan="' + plan + '"]');
      const msg = btn.parentElement.parentElement.querySelector('.coupon-msg');
      const priceEl = document.getElementById('price-' + plan);
      const codes = JSON.parse(btn.dataset.codes || '{}');
      const code = (input?.value || '').trim().toUpperCase();
      if (codes[code]) {
        const discount = codes[code];
        const originalPrice = parseFloat(priceEl?.dataset.original || priceEl?.textContent?.replace('€','') || '0');
        if (!priceEl?.dataset.original && priceEl) priceEl.dataset.original = String(originalPrice);
        const newPrice = (originalPrice * (1 - discount / 100)).toFixed(2);
        if (priceEl) priceEl.textContent = '€' + newPrice;
        if (msg) { msg.textContent = '✅ ' + btn.dataset.applied + ' (-' + discount + '%)'; msg.className = 'coupon-msg text-xs mt-1.5 text-green-400'; }
      } else if (code) {
        if (msg) { msg.textContent = '❌ ' + btn.dataset.invalid; msg.className = 'coupon-msg text-xs mt-1.5 text-red-400'; }
      }
    });
  });
</script>
