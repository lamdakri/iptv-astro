---
import { getWhatsAppUrl } from '../i18n/whatsapp';
import { getLangFromUrl, useTranslations } from '../i18n/ui';
import WhatsAppIcon from './icons/WhatsAppIcon.astro';

interface Props {
  title: string;
  subtitle: string;
  headerPlan: string;
  headerMonthly: string;
  headerOurPrice: string;
  headerSavings: string;
  monthlyRate: string;
  eyebrow: string;
  bestDeal: string;
  ctaText: string;
  ctaButton: string;
  rows: {
    duration: string;
    monthlyCost: string;
    ourPrice: string;
    savings: string;
    savingsPct: string;
    featured?: boolean;
  }[];
}

const { title, subtitle, headerPlan, headerMonthly, headerOurPrice, headerSavings, monthlyRate, eyebrow, bestDeal, ctaText, ctaButton, rows } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="section section-alt">
  <div class="container-custom">
    <div class="text-center mb-14">
      <span class="section-eyebrow">{eyebrow}</span>
      <h2 class="section-title">{title}</h2>
      <p class="section-subtitle mx-auto">{subtitle}</p>
    </div>

    <!-- Desktop table -->
    <div class="hidden md:block max-w-4xl mx-auto reveal">
      <div class="glass-card overflow-hidden">
        <div class="grid grid-cols-4 text-sm font-semibold text-surface-300 border-b border-surface-800/50 bg-surface-900/30 px-6 py-4">
          <div>{headerPlan}</div>
          <div>{headerMonthly} <span class="text-surface-500 font-normal text-xs">({monthlyRate})</span></div>
          <div>{headerOurPrice}</div>
          <div>{headerSavings}</div>
        </div>
        {rows.map((row) => (
          <div class={`grid grid-cols-4 items-center px-6 py-5 border-b border-surface-800/30 last:border-0 transition-colors hover:bg-surface-900/20 ${row.featured ? 'savings-row-featured bg-brand-900/10 border-l-2 border-l-brand-500' : ''}`}>
            <div class="font-semibold text-white text-lg">{row.duration}</div>
            <div class="text-surface-400 line-through">{row.monthlyCost}</div>
            <div class="font-extrabold gradient-text-static text-lg">{row.ourPrice}</div>
            <div class="flex flex-col gap-0.5">
              <span class="font-bold text-green-400">{row.savings}</span>
              <span class="text-xs text-green-500/70">{row.savingsPct}</span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Mobile cards -->
    <div class="md:hidden space-y-4 reveal">
      {rows.map((row) => (
        <div class={`glass-card p-5 ${row.featured ? 'border-brand-500/40 bg-brand-900/10' : ''}`}>
          <div class="flex items-center justify-between mb-3">
            <span class="font-bold text-white text-lg">{row.duration}</span>
            {row.featured && (
              <span class="pricing-badge pricing-badge--sale text-xs">{bestDeal}</span>
            )}
          </div>
          <div class="space-y-2 text-sm">
            <div class="flex justify-between">
              <span class="text-surface-400">{headerMonthly} ({monthlyRate})</span>
              <span class="text-surface-400 line-through">{row.monthlyCost}</span>
            </div>
            <div class="flex justify-between">
              <span class="text-surface-400">{headerOurPrice}</span>
              <span class="font-extrabold gradient-text-static text-lg">{row.ourPrice}</span>
            </div>
            <div class="flex justify-between pt-2 border-t border-surface-800/30">
              <span class="text-surface-400">{headerSavings}</span>
              <span class="font-bold text-green-400">{row.savings} <span class="text-xs text-green-500/70">({row.savingsPct})</span></span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-12 reveal">
      <p class="text-surface-400 text-sm mb-4">{ctaText}</p>
      <a
        href={getWhatsAppUrl(t('whatsapp.bestValue') || 'Hi! I want the best value 1 Year plan.')}
        class="btn-whatsapp text-lg px-10 py-4"
        target="_blank" rel="noopener noreferrer"
      >
        <WhatsAppIcon class="h-5 w-5" />
        {ctaButton}
      </a>
    </div>
  </div>
</section>
<style is:global>
/* ============================================
   SAVINGS COMPARISON
   ============================================ */

.savings-row-featured {
  position: relative;
  background: linear-gradient(135deg, rgba(124, 58, 237, 0.12), rgba(34, 211, 238, 0.05)) !important;
  animation: savings-glow 3s ease-in-out infinite;
}

@keyframes savings-glow {
  0%, 100% { box-shadow: inset 0 0 20px rgba(124, 58, 237, 0.05); }
  50% { box-shadow: inset 0 0 30px rgba(124, 58, 237, 0.15); }
}

.savings-featured-badge {
  position: absolute;
  top: -10px;
  right: 20px;
  z-index: 2;
}
</style>
