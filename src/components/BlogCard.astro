---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import { useTranslations } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  slug: string;
  lang: string;
  date: Date;
  category?: string;
  image?: ImageMetadata | string;
}

const { title, description, slug, lang, date, category, image } = Astro.props;
const t = useTranslations(lang);
const formattedDate = new Date(date).toLocaleDateString(
  { en: 'en-US', fr: 'fr-FR', ar: 'ar-SA', es: 'es-ES' }[lang] || 'en-US',
  { year: 'numeric', month: 'long', day: 'numeric' }
);
---

<article class="blog-card">
  {image && (
    <div class="blog-image-wrapper">
      <Image
          src={image as ImageMetadata}
          alt={title}
          class="w-full h-48 object-cover"
          loading="lazy"
          format={(image as ImageMetadata).format === 'svg' ? undefined : 'webp'}
          widths={[400, 800]}
          sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
        />
    </div>
  )}
  <div class="p-6">
    {category && (
      <span class="text-xs font-semibold text-brand-400 uppercase tracking-wider">{category}</span>
    )}
    <h3 class="text-xl font-bold text-white mt-2 mb-3">
      <a href={`/${lang}/blog/${slug}/`} class="hover:text-brand-400 transition-colors">
        {title}
      </a>
    </h3>
    <p class="text-surface-400 text-sm line-clamp-3">{description}</p>
    <div class="mt-4 flex items-center justify-between">
      <span class="text-xs text-surface-500">{t('blog.publishedOn')} {formattedDate}</span>
      <a href={`/${lang}/blog/${slug}/`} class="text-sm text-brand-400 hover:text-brand-300 font-medium transition-colors">
        {t('blog.readMore')} →
      </a>
    </div>
  </div>
</article>
<style is:global>
/* ============================================
   BLOG CARDS
   ============================================ */

.blog-card {
  background: rgba(15, 23, 42, 0.4);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(148, 163, 184, 0.06);
  border-radius: 1.25rem;
  overflow: hidden;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
}
.blog-card:hover {
  border-color: rgba(124, 58, 237, 0.2);
  box-shadow: 0 15px 40px rgba(0, 0, 0, 0.35);
  transform: translateY(-5px);
}

/* Blog card image hover with overlay */
.blog-card .blog-image-wrapper {
  position: relative;
  overflow: hidden;
}
.blog-card .blog-image-wrapper::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, transparent 50%, rgba(124, 58, 237, 0.3) 100%);
  opacity: 0;
  transition: opacity 0.4s ease;
}
.blog-card:hover .blog-image-wrapper::after {
  opacity: 1;
}
.blog-card img {
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}
.blog-card:hover img {
  transform: scale(1.08);
}
</style>
