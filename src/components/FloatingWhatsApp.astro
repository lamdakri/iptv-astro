---
import { getLangFromUrl, useTranslations } from '../i18n/ui';
import { getWhatsAppUrl, getWhatsAppTrialMsg } from '../i18n/whatsapp';
import WhatsAppIcon from './icons/WhatsAppIcon.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<a
  id="floating-wa-btn"
  data-track="whatsapp_click"
  data-track-label="Floating Button"
  data-track-category="conversion"
  href={getWhatsAppUrl(getWhatsAppTrialMsg(t))}
  target="_blank"
  rel="noopener noreferrer"
  class="floating-whatsapp"
  aria-label={t('cta.trial')}
>
  <WhatsAppIcon class="h-5 w-5" variant="full" />
  <span class="hidden sm:inline font-medium text-sm">{t('cta.trial.short')}</span>
</a>

<script>
  (function() {
    const btn = document.getElementById('floating-wa-btn');
    if (!btn) return;
    let timeout: ReturnType<typeof setTimeout> | undefined;
    const floatingBtn = btn;
    function checkFooter() {
      const scrollBottom = window.innerHeight + window.scrollY;
      const docHeight = document.documentElement.scrollHeight;
      const nearBottom = docHeight - scrollBottom < 250;
      if (nearBottom) {
        floatingBtn.classList.add('floating-whatsapp--hidden');
      } else {
        floatingBtn.classList.remove('floating-whatsapp--hidden');
      }
    }
    window.addEventListener('scroll', function() {
      clearTimeout(timeout);
      timeout = setTimeout(checkFooter, 50);
    }, { passive: true });
    checkFooter();
  })();
</script>
<style is:global>
/* ============================================
   FLOATING WHATSAPP
   ============================================ */

@keyframes pulse-whatsapp {
  0% { box-shadow: 0 0 0 0 rgba(37, 211, 102, 0.5); }
  70% { box-shadow: 0 0 0 18px rgba(37, 211, 102, 0); }
  100% { box-shadow: 0 0 0 0 rgba(37, 211, 102, 0); }
}

.floating-whatsapp {
  position: fixed;
  bottom: 1.5rem;
  right: 1.5rem;
  z-index: 50;
  display: flex;
  align-items: center;
  gap: 0.75rem;
  background: linear-gradient(135deg, #25D366, #128C7E);
  color: white;
  padding: 0.75rem 1.5rem;
  border-radius: 9999px;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  animation: pulse-whatsapp 2.5s ease-in-out infinite;
  opacity: 1;
  transform: translateY(0);
}
.floating-whatsapp:hover {
  transform: scale(1.08);
  box-shadow: 0 12px 40px rgba(37, 211, 102, 0.45);
  animation: none;
}
.floating-whatsapp--hidden {
  opacity: 0;
  transform: translateY(20px);
  pointer-events: none;
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
}
[dir="rtl"] .floating-whatsapp {
  right: auto;
  left: 1.5rem;
}

/* Smaller on mobile */
@media (max-width: 640px) {
  .floating-whatsapp {
    bottom: 1rem;
    right: 1rem;
    padding: 0.625rem;
    gap: 0;
    border-radius: 50%;
    min-width: 3rem;
    min-height: 3rem;
    justify-content: center;
  }
  .floating-whatsapp svg {
    width: 1.25rem;
    height: 1.25rem;
  }
  [dir="rtl"] .floating-whatsapp {
    right: auto;
    left: 1rem;
  }
}
</style>
