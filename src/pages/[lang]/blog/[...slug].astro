---
import { getCollection, type CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import { useTranslations } from "../../../i18n/ui";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import BlogCard from "../../../components/BlogCard.astro";
import { getWhatsAppUrl, getWhatsAppTrialMsg } from "../../../i18n/whatsapp";

interface Props {
  entry: CollectionEntry<"blog">;
  alternateLangs?: { lang: string; url: string }[];
}

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);

  // Build translationKey -> posts map for proper hreflang URLs
  const translationMap = new Map<string, typeof posts>();
  for (const post of posts) {
    const key = post.data.translationKey;
    if (key) {
      if (!translationMap.has(key)) translationMap.set(key, []);
      translationMap.get(key)!.push(post);
    }
  }

  return posts.map((entry) => {
    const tKey = entry.data.translationKey;
    const alternateLangs = tKey
      ? (translationMap.get(tKey) || [])
          .filter((p) => p.data.lang !== entry.data.lang)
          .map((p) => ({
            lang: p.data.lang,
            url: `/${p.data.lang}/blog/${p.slug}/`,
          }))
      : undefined;

    return {
      params: { lang: entry.data.lang, slug: entry.slug },
      props: { entry, alternateLangs },
    };
  });
}

const { entry, alternateLangs } = Astro.props;
const { Content } = await entry.render();
const { lang } = Astro.params;
const t = useTranslations(lang);

const relatedPosts = (
  await getCollection(
    "blog",
    ({ data, slug }) => !data.draft && data.lang === lang && slug !== entry.slug,
  )
)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const pageTitle = entry.data.title + " | " + t("blog.title") + " | " + t("site.name");

const pageUrl = Astro.url.href;

const ogImageUrl = entry.data.image ? new URL(entry.data.image.src, Astro.site).href : undefined;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": pageUrl + "#article",
  headline: entry.data.title,
  description: entry.data.description,
  image: entry.data.image
    ? new URL(entry.data.image.src, Astro.site || "https://iptv4kworld.com").href
    : undefined,
  author: { "@type": "Person", name: entry.data.author },
  publisher: {
    "@type": "Organization",
    name: "IPTV 4K World",
    logo: {
      "@type": "ImageObject",
      url: new URL("/favicon.svg", Astro.site || "https://iptv4kworld.com").href,
    },
  },
  datePublished: entry.data.date.toISOString(),
  dateModified: (entry.data.updatedDate || entry.data.date).toISOString(),
  mainEntityOfPage: { "@id": pageUrl },
  keywords: entry.data.keywords?.join(", ") || undefined,
};
---

<BaseLayout
  title={pageTitle}
  description={entry.data.description}
  ogImage={ogImageUrl}
  ogType="article"
  articlePublishedTime={entry.data.date.toISOString()}
  articleModifiedTime={entry.data.updatedDate ? entry.data.updatedDate.toISOString() : undefined}
  articleAuthor={entry.data.author}
  articleTags={entry.data.keywords || []}
  articleSection={entry.data.category}
  keywords={entry.data.keywords?.join(", ")}
  schema={articleSchema}
  alternateLangs={alternateLangs}
>
  {
    entry.data.howToSteps && entry.data.howToSteps.length > 0 && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify({
          "@context": "https://schema.org",
          "@type": "HowTo",
          name: entry.data.title,
          description: entry.data.description,
          step: entry.data.howToSteps.map((step, i) => ({
            "@type": "HowToStep",
            position: i + 1,
            name: step.name,
            text: step.text,
            ...(step.url && { url: step.url }),
            ...(step.image && { image: step.image }),
          })),
          ...(entry.data.image && {
            image: {
              "@type": "ImageObject",
              url: new URL(entry.data.image.src, Astro.site || "https://iptv4kworld.com").href,
            },
          }),
        })}
        is:inline
      />
    )
  }

  <article class="pt-32 pb-20">
    <div class="container-custom">
      <!-- ===== BREADCRUMB ===== -->
      <Breadcrumb
        items={[
          { label: t("breadcrumb.home"), href: "/" + lang + "/" },
          { label: t("blog.title"), href: "/" + lang + "/blog/" },
          { label: entry.data.title },
        ]}
      />

      <!-- ===== HEADER ===== -->
      <header class="mb-10 text-center reveal">
        {
          entry.data.category && (
            <span class="inline-block text-xs font-semibold text-brand-400 uppercase tracking-wider bg-brand-400/10 px-3 py-1 rounded-full mb-4">
              {entry.data.category}
            </span>
          )
        }
        <h1 class="text-3xl md:text-5xl font-extrabold text-white mt-2 mb-6 leading-tight">
          {entry.data.title}
        </h1>
        <div class="flex items-center justify-center gap-4 text-sm text-surface-400">
          <span>{entry.data.author}</span>
          <span class="text-surface-600">·</span>
          <time datetime={entry.data.date.toISOString()}>
            {
              new Date(entry.data.date).toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })
            }
          </time>
          {
            entry.data.tags && entry.data.tags.length > 0 && (
              <>
                <span class="text-surface-600">·</span>
                <span class="text-surface-500">{entry.data.tags.slice(0, 2).join(", ")}</span>
              </>
            )
          }
        </div>
      </header>

      <!-- ===== FEATURED IMAGE ===== -->
      {
        entry.data.image && (
          <Image
            src={entry.data.image}
            alt={entry.data.title}
            class="w-full max-h-96 object-cover rounded-2xl mb-10 reveal"
            loading="eager"
            format={entry.data.image.format === "svg" ? undefined : "webp"}
            widths={[400, 800, 1600]}
            sizes="(max-width: 768px) 100vw, 768px"
            fetchpriority="high"
          />
        )
      }

      <!-- ===== TABLE OF CONTENTS (collapsible) ===== -->
      <div class="max-w-3xl mx-auto mb-10" id="toc-wrapper">
        <details
          open
          class="glass-card rounded-xl overflow-hidden border border-surface-700/50 group reveal"
          data-reveal-delay="100"
        >
          <summary
            class="flex items-center justify-between px-6 py-4 cursor-pointer select-none hover:bg-surface-800/30 transition-colors duration-200"
          >
            <span class="text-lg font-semibold text-white flex items-center gap-2">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-brand-400"
                ><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"
                ></line><line x1="8" y1="18" x2="21" y2="18"></line><line
                  x1="3"
                  y1="6"
                  x2="3.01"
                  y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line
                  x1="3"
                  y1="18"
                  x2="3.01"
                  y2="18"></line></svg
              >
              {t("blog.toc") || "Table of Contents"}
            </span>
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              class="text-surface-400 transition-transform duration-300 group-open:rotate-180"
              ><polyline points="6 9 12 15 18 9"></polyline></svg
            >
          </summary>
          <nav id="toc-list" class="px-6 pb-4 text-sm">
            <p class="text-surface-500 py-4 text-center">Loading table of contents...</p>
          </nav>
        </details>
      </div>

      <!-- ===== PROSE CONTENT ===== -->
      <div
        class="prose prose-invert prose-lg max-w-3xl mx-auto reveal"
        data-reveal-delay="150"
        id="blog-content"
      >
        <Content />
      </div>

      <!-- ===== SHARE BUTTONS ===== -->
      <div
        class="max-w-3xl mx-auto mt-12 pt-8 border-t border-surface-800 reveal"
        data-reveal-delay="200"
      >
        <div class="flex flex-wrap items-center gap-3">
          <span class="text-sm font-semibold text-surface-400 mr-1"
            >{t("blog.shareThis") || "Share This"}:</span
          >
          <!-- Twitter/X -->
          <a
            href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(pageUrl)}&text=${encodeURIComponent(entry.data.title)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm font-medium bg-surface-800 text-surface-300 border border-surface-700 hover:border-brand-500 hover:text-brand-400 transition-all duration-300 share-pill"
            aria-label="Share on Twitter"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
              ></path></svg
            >
            Twitter
          </a>
          <!-- Facebook -->
          <a
            href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(pageUrl)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm font-medium bg-surface-800 text-surface-300 border border-surface-700 hover:border-brand-500 hover:text-brand-400 transition-all duration-300 share-pill"
            aria-label="Share on Facebook"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
              ></path></svg
            >
            Facebook
          </a>
          <!-- WhatsApp -->
          <a
            href={`https://wa.me/?text=${encodeURIComponent(entry.data.title + " " + pageUrl)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm font-medium bg-surface-800 text-surface-300 border border-surface-700 hover:border-brand-500 hover:text-brand-400 transition-all duration-300 share-pill"
            aria-label="Share on WhatsApp"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path></svg
            >
            WhatsApp
          </a>
          <!-- Copy Link -->
          <button
            id="copy-link-btn"
            class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm font-medium bg-surface-800 text-surface-300 border border-surface-700 hover:border-brand-500 hover:text-brand-400 transition-all duration-300 share-pill"
            aria-label="Copy link"
            data-copied-text={t("blog.copied") || "Copied!"}
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path
                d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg
            >
            <span id="copy-link-text">{t("blog.copyLink") || "Copy Link"}</span>
          </button>
        </div>
      </div>

      <!-- ===== AUTHOR CARD ===== -->
      <div class="max-w-3xl mx-auto mt-12 reveal" data-reveal-delay="250">
        <div
          class="glass-card rounded-2xl p-6 md:p-8 flex flex-col sm:flex-row items-start gap-5 border border-surface-700/50"
        >
          <!-- Avatar -->
          <div
            class="flex-shrink-0 w-16 h-16 rounded-full bg-gradient-to-br from-brand-600 to-purple-600 flex items-center justify-center text-white text-xl font-bold shadow-lg shadow-brand-600/20"
          >
            {entry.data.author?.charAt(0) || "I"}
          </div>
          <!-- Info -->
          <div>
            <p class="text-xs font-semibold text-brand-400 uppercase tracking-wider mb-1">
              {t("blog.writtenBy") || "Written by"}
            </p>
            <p class="text-lg font-bold text-white mb-2">{entry.data.author}</p>
            <p class="text-sm text-surface-400 leading-relaxed">
              {t("blog.authorBio") || "IPTV streaming expert and tech writer at IPTV 4K World."}
            </p>
            <!-- Author tags -->
            <div class="flex flex-wrap gap-2 mt-3">
              {
                entry.data.tags &&
                  entry.data.tags
                    .slice(0, 3)
                    .map((tag) => (
                      <span class="text-xs px-2 py-0.5 rounded-full bg-surface-700 text-surface-400">
                        {tag}
                      </span>
                    ))
              }
            </div>
          </div>
        </div>
      </div>

      <!-- ===== CTA ===== -->
      <div
        class="max-w-2xl mx-auto mt-16 p-8 rounded-2xl bg-gradient-to-r from-brand-900/30 to-surface-900 border border-surface-800 text-center reveal"
      >
        <h2 class="text-2xl font-bold text-white mb-3">{t("cta.final.title")}</h2>
        <p class="text-surface-400 mb-6">{t("cta.final.subtitle")}</p>
        <a
          href={getWhatsAppUrl(getWhatsAppTrialMsg(t))}
          class="btn-whatsapp"
          target="_blank"
          rel="noopener noreferrer"
        >
          {t("cta.final.button")}
        </a>
      </div>

      <!-- ===== RELATED POSTS ===== -->
      {
        relatedPosts.length > 0 && (
          <section class="mt-20">
            <h2 class="text-2xl font-bold text-white mb-8">{t("blog.relatedPosts")}</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              {relatedPosts.map((post, i) => (
                <div class="reveal reveal-scale" data-reveal-delay={String(i * 120)}>
                  <BlogCard
                    title={post.data.title}
                    description={post.data.description}
                    slug={post.slug}
                    lang={lang}
                    date={post.data.date}
                    category={post.data.category}
                    image={post.data.image}
                  />
                </div>
              ))}
            </div>
          </section>
        )
      }
    </div>
  </article>
</BaseLayout>

<!-- ===== CLIENT-SIDE SCRIPTS ===== -->
<script is:inline>
  // ── Table of Contents Generator ──
  (function () {
    var tocList = document.getElementById("toc-list");
    var content = document.getElementById("blog-content");
    if (!tocList || !content) return;

    var headings = content.querySelectorAll("h2, h3");
    if (headings.length === 0) {
      tocList.innerHTML = '<p class="text-surface-500 text-sm py-2">No sections found.</p>';
      return;
    }

    var html = '<ul class="space-y-1 border-l-2 border-surface-700 pl-4">';
    headings.forEach(function (h, index) {
      // Generate a robust ID that works with any language
      var slug = h.textContent
        .toLowerCase()
        .replace(/[^a-z0-9\u00C0-\u024F\u0600-\u06FF\u0750-\u077F]+/g, "-")
        .replace(/(^-|-$)/g, "");
      if (!slug || slug.length < 2) slug = "section-" + (index + 1);
      // Ensure uniqueness
      var baseId = slug;
      var counter = 1;
      var el = document.getElementById(slug);
      while (el && el !== h) {
        slug = baseId + "-" + counter++;
        el = document.getElementById(slug);
      }
      h.id = slug;

      var isH3 = h.tagName === "H3";
      var paddingClass = isH3 ? "pl-3 text-xs" : "text-sm font-medium";
      html += '<li class="' + paddingClass + '">';
      html +=
        '<a href="#' +
        slug +
        '" class="block py-1 text-surface-400 hover:text-brand-400 transition-colors duration-200 truncate" title="' +
        h.textContent +
        '">';
      html += h.textContent;
      html += "</a>";
      html += "</li>";
    });
    html += "</ul>";
    tocList.innerHTML = html;
  })();

  // ── Copy Link Button ──
  (function () {
    var btn = document.getElementById("copy-link-btn");
    var label = document.getElementById("copy-link-text");
    if (!btn || !label) return;

    var originalText = label.textContent;
    var copiedText = btn.dataset.copiedText || "Copied!";
    btn.addEventListener("click", function () {
      navigator.clipboard
        .writeText(window.location.href)
        .then(function () {
          label.textContent = copiedText;
          btn.classList.add("border-green-500", "text-green-400");
          setTimeout(function () {
            label.textContent = originalText;
            btn.classList.remove("border-green-500", "text-green-400");
          }, 2000);
        })
        .catch(function () {
          // Clipboard API unavailable — show error state briefly
          label.textContent = "⚠";
          label.style.color = "#f87171";
          label.style.borderColor = "#f87171";
          setTimeout(function () {
            label.textContent = originalText;
            label.style.color = "";
            label.style.borderColor = "";
          }, 2000);
        });
    });
  })();

  // ── Smooth scroll for TOC links ──
  (function () {
    var tocList = document.getElementById("toc-list");
    if (!tocList) return;
    tocList.addEventListener("click", function (e) {
      var link = e.target.closest("a");
      if (!link) return;
      e.preventDefault();
      var target = document.querySelector(link.getAttribute("href"));
      if (target) {
        target.scrollIntoView({ behavior: "smooth", block: "start" });
      }
    });
  })();
</script>

<style is:global>
  /* TOC hover effect */
  #toc-list a:hover {
    padding-left: 4px;
    transition: padding-left 0.2s ease;
  }

  /* rehype-autolink-headings anchor styling */
  .heading-anchor {
    display: inline-block;
    margin-left: 0.5rem;
    opacity: 0;
    transition: opacity 0.2s ease;
    text-decoration: none;
  }
  .heading-anchor .anchor-icon {
    color: rgb(129, 140, 248); /* brand-400 */
    font-size: 0.85em;
    font-weight: 400;
  }
  h1:hover .heading-anchor,
  h2:hover .heading-anchor,
  h3:hover .heading-anchor,
  h4:hover .heading-anchor {
    opacity: 1;
  }
  .heading-anchor:hover .anchor-icon {
    color: rgb(165, 180, 252); /* brand-300 - lighter on hover */
  }

  /* Offset for fixed header when navigating via anchor links */
  h1[id],
  h2[id],
  h3[id],
  h4[id] {
    scroll-margin-top: 100px;
  }

  /* Share buttons hover polish */
  .share-pill:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.15);
  }
</style>
