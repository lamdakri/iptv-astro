---
import { LANGUAGES } from '../i18n/ui';

interface Props {
  lang: string;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
---

<div class="lang-switcher">
  {
    Object.entries(LANGUAGES).map(([code, config]) => {
      const isActive = code === lang;
      const targetPath = `/${code}${currentPath}`;
      return (
        <a
          href={targetPath}
          class={`lang-option ${isActive ? 'active' : ''}`}
          aria-current={isActive ? 'page' : undefined}
          title={config.label}
        >
          <span class="text-base leading-none">{config.flag}</span>
        </a>
      );
    })
  }
</div>
<style is:global>
/* ============================================
   LANGUAGE SWITCHER
   ============================================ */

.lang-switcher {
  display: flex;
  align-items: center;
  gap: 1px;
  background: rgba(30, 41, 59, 0.4);
  border-radius: 0.5rem;
  padding: 2px;
  border: 1px solid rgba(148, 163, 184, 0.08);
}
.lang-option {
  padding: 0.2rem 0.35rem;
  border-radius: 0.375rem;
  font-size: 0.75rem;
  line-height: 1;
  transition: all 0.2s ease;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 1.5rem;
  opacity: 0.5;
}
.lang-option.active {
  background: linear-gradient(135deg, var(--color-brand-600), var(--color-brand-500));
  opacity: 1;
  box-shadow: 0 1px 6px rgba(124, 58, 237, 0.3);
}
.lang-option:not(.active):hover {
  opacity: 0.8;
  background: rgba(124, 58, 237, 0.15);
}
</style>
