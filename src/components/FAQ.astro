---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  subtitle?: string;
  eyebrow?: string;
  items: FAQItem[];
}

const { title, subtitle, eyebrow, items } = Astro.props;
---

<section class="section section-alt">
  <div class="container-custom">
    <div class="text-center mb-14">
      <span class="section-eyebrow">{eyebrow}</span>
      <h2 class="section-title">{title}</h2>
      {subtitle && <p class="section-subtitle mx-auto">{subtitle}</p>}
    </div>
    <div class="max-w-3xl mx-auto space-y-3">
      {items.map((item, i) => (
        <details class="faq-item group reveal" data-reveal-delay={String(i * 80)}>
          <summary>
            <span>{item.question}</span>
            <span class="faq-toggle">+</span>
          </summary>
          <div class="faq-answer">
            <p class="mt-5 text-surface-400 leading-relaxed pt-4 border-t border-surface-800/50">{item.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
<style is:global>
/* ============================================
   FAQ ITEMS
   ============================================ */

.faq-item {
  background: rgba(15, 23, 42, 0.4);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(148, 163, 184, 0.06);
  border-radius: 1rem;
  padding: 1.5rem 1.75rem;
  cursor: pointer;
  transition: all 0.3s ease;
}
.faq-item:hover {
  border-color: rgba(124, 58, 237, 0.2);
}
.faq-item[open] {
  border-color: rgba(124, 58, 237, 0.3);
  box-shadow: 0 0 25px rgba(124, 58, 237, 0.06);
}
.faq-item summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  color: white;
  font-weight: 600;
  list-style: none;
}
.faq-item summary::-webkit-details-marker {
  display: none;
}
.faq-item summary::marker {
  display: none;
  content: '';
}

/* FAQ smooth open/close animation */
.faq-item .faq-answer {
  overflow: hidden;
  max-height: 0;
  opacity: 0;
  transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease, margin 0.3s ease;
}
.faq-item[open] .faq-answer {
  max-height: 1200px;
  opacity: 1;
}

.faq-toggle {
  color: var(--color-brand-400);
  font-size: 1.5rem;
  line-height: 1;
  transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  flex-shrink: 0;
}
.faq-item[open] .faq-toggle {
  transform: rotate(45deg);
  color: var(--color-cyan-400);
}
</style>
