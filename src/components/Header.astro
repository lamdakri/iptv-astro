---
import { getLangFromUrl, useTranslations } from '../i18n/ui';
import LanguageSwitcher from './LanguageSwitcher.astro';
import WhatsAppIcon from './icons/WhatsAppIcon.astro';
import { getWhatsAppUrl, getWhatsAppTrialMsg } from '../i18n/whatsapp';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentPath = Astro.url.pathname.replace(/^\/[a-z]{2}\/?/, '/');
---

<header class="sticky-header">
  <nav class="container-custom flex items-center justify-between h-14 md:h-16">
    <!-- Logo -->
    <a href={`/${lang}/`} class="flex items-center gap-2 group">
      <span class="text-xl md:text-2xl transition-transform duration-300 group-hover:scale-110">📡</span>
      <span class="text-sm md:text-base font-bold gradient-text hidden sm:inline">{t('site.name')}</span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-0.5">
      <a href={`/${lang}/`} class="nav-link px-2.5 py-1.5 text-xs font-medium" data-track="nav_click" data-track-label="Home">{t('nav.home')}</a>
      <a href={`/${lang}/pricing/`} class="nav-link px-2.5 py-1.5 text-xs font-medium" data-track="nav_click" data-track-label="Pricing">{t('nav.pricing')}</a>
      <a href={`/${lang}/blog/`} class="nav-link px-2.5 py-1.5 text-xs font-medium" data-track="nav_click" data-track-label="Blog">{t('nav.blog')}</a>
      <div class="ml-2">
        <LanguageSwitcher lang={lang} currentPath={currentPath} />
      </div>

      <a
        href={getWhatsAppUrl(getWhatsAppTrialMsg(t))}
        class="btn-whatsapp text-xs px-3.5 py-2 ml-2"
        target="_blank"
        rel="noopener noreferrer"
        data-track="whatsapp_click"
        data-track-label="Header Desktop"
        data-track-category="conversion"
      >
        <WhatsAppIcon class="h-3.5 w-3.5" />
        <span>{t('cta.trial.short')}</span>
      </a>
    </div>

    <!-- Mobile Hamburger -->
    <button id="mobile-menu-btn" class="hamburger md:hidden" aria-label={t('a11y.menuToggle')} aria-expanded="false" aria-controls="mobile-menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>

  <!-- Mobile Menu Overlay -->
  <div id="mobile-menu" class="mobile-menu">
    <div class="mobile-menu-inner">
      <a href={`/${lang}/`} data-track="nav_click" data-track-label="Mobile Home" class="mobile-menu-link">{t('nav.home')}</a>
      <a href={`/${lang}/pricing/`} data-track="nav_click" data-track-label="Mobile Pricing" class="mobile-menu-link">{t('nav.pricing')}</a>
      <a href={`/${lang}/blog/`} data-track="nav_click" data-track-label="Mobile Blog" class="mobile-menu-link">{t('nav.blog')}</a>
      <div class="mt-4">
        <LanguageSwitcher lang={lang} currentPath={currentPath} />
      </div>
      <a
        href={getWhatsAppUrl(getWhatsAppTrialMsg(t))}
        class="btn-whatsapp text-sm px-6 py-3 mt-6"
        target="_blank"
        rel="noopener noreferrer"
        data-track="whatsapp_click"
        data-track-label="Header Mobile"
        data-track-category="conversion"
      >
        {t('cta.trial.short')}
      </a>
    </div>
  </div>
</header>

<script>
  (function() {
    // Mobile menu toggle
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    if (btn && menu) {
      btn.addEventListener('click', () => {
        btn.classList.toggle('open');
        menu.classList.toggle('open');
        const expanded = btn.classList.contains('open');
        btn.setAttribute('aria-expanded', String(expanded));
      });

      // Close mobile menu on link click
      menu.querySelectorAll('a').forEach(function(link) {
        link.addEventListener('click', function() {
          btn.classList.remove('open');
          menu.classList.remove('open');
          btn.setAttribute('aria-expanded', 'false');
        });
      });
    }

    // Header scroll effect — add .scrolled class when scrolled past threshold
    const header = document.querySelector('.sticky-header');
    if (header) {
      var ticking = false;
      function updateHeader() {
        if (window.scrollY > 20) {
          header.classList.add('scrolled');
        } else {
          header.classList.remove('scrolled');
        }
        ticking = false;
      }
      window.addEventListener('scroll', function() {
        if (!ticking) {
          window.requestAnimationFrame(updateHeader);
          ticking = true;
        }
      }, { passive: true });
      // Check initial state
      updateHeader();
    }
  })();
</script>
