---
import { useTranslations, LANGUAGES } from '../../i18n/ui';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { WHATSAPP_NUMBER as WA } from '../../i18n/whatsapp';
import WhatsAppIcon from '../../components/icons/WhatsAppIcon.astro';

export function getStaticPaths() {
  return Object.keys(LANGUAGES).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang);
const whatsappUrl = `https://wa.me/${WA}?text=${encodeURIComponent(t('whatsapp.help'))}`;
const pageTitle = t('contact.title') + ' | ' + t('site.name');
const pageUrl = Astro.url.href;

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: pageTitle,
  description: t('contact.subtitle'),
  url: pageUrl,
  inLanguage: lang,
  isPartOf: {
    '@type': 'WebSite',
    name: t('site.name'),
    url: Astro.site?.href || 'https://iptv4kworld.com',
  },
  about: {
    '@type': 'Thing',
    name: 'Contact Page',
  },
};
---

<BaseLayout title={pageTitle} description={t('contact.subtitle')} keywords={t('seo.keywords')} schema={pageSchema}>
  <Breadcrumb items={[{
    label: t('breadcrumb.home'), href: `/${lang}/` },
    { label: t('contact.title') }
  ]} />

  <section class="section">
    <div class="container-custom">
      <div class="text-center mb-14">
        <span class="section-eyebrow mx-auto justify-center">{t('contact.title')}</span>
        <h1 class="section-title">{t('contact.title')}</h1>
        <p class="section-subtitle mx-auto">{t('contact.subtitle')}</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 maxw-4xl mx-auto">
        <!-- Form -->
        <div class="glass-card p-8 reveal reveal-scale">
          <h2 class="text-xl font-bold text-white mb-1">{t('contact.formTitle')}</h2>
          <p class="text-surface-400 text-sm mb-6">{t('contact.formDesc')}</p>
          <form id="contact-form" class="space-y-5"
            data-wa-number={WA}
            data-wa-subject={t('contact.whatsappSubject')}
            data-label-name={t('contact.name')}
            data-label-email={t('contact.email')}
            data-label-phone={t('contact.phone')}
            data-label-message={t('contact.message')}>
            <div>
              <label for="contact-name" class="block text-sm font-medium text-surface-300 mb-1.5">{t('contact.name')} *</label>
              <input type="text" id="contact-name" name="name" required autocomplete="name"
                class="w-full px-4 py-3 rounded-lg bg-surface-800/60 border border-surface-700/40 text-white text-sm placeholder:text-surface-500 focus:outline-none focus:border-brand-500/50 transition-colors" />
            </div>
            <div>
              <label for="contact-email" class="block text-sm font-medium text-surface-300 mb-1.5">{t('contact.email')} *</label>
              <input type="email" id="contact-email" name="email" required autocomplete="email"
                class="w-full px-4 py-3 rounded-lg bg-surface-800/60 border border-surface-700/40 text-white text-sm placeholder:text-surface-500 focus:outline-none focus:border-brand-500/50 transition-colors" />
            </div>
            <div>
              <label for="contact-phone" class="block text-sm font-medium text-surface-300 mb-1.5">{t('contact.phone')}</label>
              <input type="tel" id="contact-phone" name="phone" autocomplete="tel"
                class="w-full px-4 py-3 rounded-lg bg-surface-800/60 border border-surface-700/40 text-white text-sm placeholder:text-surface-500 focus:outline-none focus:border-brand-500/50 transition-colors" />
            </div>
            <div>
              <label for="contact-message" class="block text-sm font-medium text-surface-300 mb-1.5">{t('contact.message')} *</label>
              <textarea id="contact-message" name="message" required rows="4"
                class="w-full px-4 py-3 rounded-lg bg-surface-800/60 border border-surface-700/40 text-white text-sm placeholder:text-surface-500 focus:outline-none focus:border-brand-500/50 transition-colors resize-none"></textarea>
            </div>
            <button type="submit" id="contact-btn"
              class="btn-primary w-full text-lg">
              {t('contact.submit')}
            </button>
            <p id="contact-success" class="text-green-400 text-sm text-center hidden">{t('contact.success')}</p>
          </form>
        </div>

        <!-- WhatsApp CARD -->
        <div class="space-y-6 reveal reveal-right">
          <div class="glass-card p-8 text-center">
            <div class="text-5xl mb-4">💡</div>
            <h2 class="text-xl font-bold text-white mb-3">{t('contact.whatsappTitle')}</h2>
            <p class="text-surface-400 text-sm mb-6">{t('contact.whatsappDesc')}</p>
            <a href={whatsappUrl} class="btn-whatsapp text-lg px-8 py-3" target="_blank" rel="noopener noreferrer" data-track="whatsapp_click" data-track-label="Contact Page" data-track-category="conversion">
              <WhatsAppIcon class="h-5 w-5" />
              {t('contact.whatsappCta')}
            </a>
            <p class="text-surface-500 text-xs mt-4">📞 24/7 Support • Reply in Minutes</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  (function() {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const msg = document.getElementById('contact-success');
    const btn = document.getElementById('contact-btn') as HTMLButtonElement | null;
    if (!form || !btn) return;
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      btn.disabled = true;

      const name = (document.getElementById('contact-name') as HTMLInputElement | null)?.value?.trim() || '';
      const email = (document.getElementById('contact-email') as HTMLInputElement | null)?.value?.trim() || '';
      const phone = (document.getElementById('contact-phone') as HTMLInputElement | null)?.value?.trim() || '';
      const message = (document.getElementById('contact-message') as HTMLTextAreaElement | null)?.value?.trim() || '';

      const waNumber = form.dataset.waNumber || '212606123321';
      const subject = form.dataset.waSubject || 'New contact from IPTV 4K World website';
      const labelName = form.dataset.labelName || 'Name';
      const labelEmail = form.dataset.labelEmail || 'Email';
      const labelPhone = form.dataset.labelPhone || 'Phone';
      const labelMessage = form.dataset.labelMessage || 'Message';

      const waMessage = [
        encodeURIComponent('\uD83D\uDCEC ' + subject),
        encodeURIComponent(''),
        encodeURIComponent('\uD83D\uDC64 ' + labelName + ': ' + name),
        encodeURIComponent('\uD83D\uDCE7 ' + labelEmail + ': ' + email),
        phone ? encodeURIComponent('\uD83D\uDCF1 ' + labelPhone + ': ' + phone) : '',
        encodeURIComponent(''),
        encodeURIComponent('\uD83D\uDCAC ' + labelMessage + ': ' + message),
      ].filter(Boolean).join('%0A');

      window.open('https://wa.me/' + waNumber + '?text=' + waMessage, '_blank');

      if (msg) msg.classList.remove('hidden');
      form.reset();
      btn.disabled = false;
    });
  })();
</script>
