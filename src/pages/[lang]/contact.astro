---
import { getLangFromUrl, useTranslations } from '../../i18n/ui';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { WHATSAPP_NUMBER as WA } from '../../i18n/whatsapp';

export function getStaticPaths() {
  return Object.keys({ en: true, fr: true, ar: true, es: true, de: true, it: true, pt: true }).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang);
const whatsappUrl = `https://wa.me/${WA}?text=${encodeURIComponent('Hello! I need help with IPTV.')}`;
const pageTitle = t('contact.title') + ' | ' + t('site.name');
---

<BaseLayout title={pageTitle} description={t('contact.subtitle')} keywords={t('seo.keywords')}>
  <Breadcrumb items={[{
    label: t('breadcrumb.home'), href: `/${lang}/` },
    { label: t('contact.title') }
  ]} />

  <section class="section">
    <div class="container-custom">
      <div class="text-center mb-14">
        <span class="section-eyebrow mx-auto justify-center">{t('contact.title')}</span>
        <h1 class="section-title">{t('contact.title')}</h1>
        <p class="section-subtitle mx-auto">{t('contact.subtitle')}</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 maxw-4xl mx-auto">
        <!-- Form -->
        <div class="glass-card p-8 reveal reveal-scale">
          <h2 class="text-xl font-bold text-white mb-1">{t('contact.formTitle')}</h2>
          <p class="text-surface-400 text-sm mb-6">{t('contact.formDesc')}</p>
          <form id="contact-form" class="space-y-5">
            <div>
              <label class="block text-sm font-medium text-surface-300 mb-1.5">{t('contact.name')} *</label>
              <input type="text" required
                class="w-full px-4 py-3 rounded-lg bg-surface-800/60 border border-surface-700/40 text-white text-sm placeholder:text-surface-500 focus:outline-none focus:border-brand-500/50 transition-colors" />
            </div>
            <div>
              <label class="block text-sm font-medium text-surface-300 mb-1.5">{t('contact.email')} *</label>
              <input type="email" required
                class="w-full px-4 py-3 rounded-lg bg-surface-800/60 border border-surface-700/40 text-white text-sm placeholder:text-surface-500 focus:outline-none focus:border-brand-500/50 transition-colors" />
            </div>
            <div>
              <label class="block text-sm font-medium text-surface-300 mb-1.5">{t('contact.phone')}</label>
              <input type="tel"
                class="w-full px-4 py-3 rounded-lg bg-surface-800/60 border border-surface-700/40 text-white text-sm placeholder:text-surface-500 focus:outline-none focus:border-brand-500/50 transition-colors" />
            </div>
            <div>
              <label class="block text-sm font-medium text-surface-300 mb-1.5">{t('contact.message')} *</label>
              <textarea required rows="4"
                class="w-full px-4 py-3 rounded-lg bg-surface-800/60 border border-surface-700/40 text-white text-sm placeholder:text-surface-500 focus:outline-none focus:border-brand-500/50 transition-colors resize-none"></textarea>
            </div>
            <button type="submit" id="contact-btn"
              class="btn-primary w-full text-lg">
              {t('contact.submit')}
            </button>
            <p id="contact-success" class="text-green-400 text-sm text-center hidden">{t('contact.success')}</p>
          </form>
        </div>

        <!-- WhatsApp CARD -->
        <div class="space-y-6 reveal reveal-right">
          <div class="glass-card p-8 text-center">
            <div class="text-5xl mb-4">💡</div>
            <h2 class="text-xl font-bold text-white mb-3">{t('contact.whatsappTitle')}</h2>
            <p class="text-surface-400 text-sm mb-6">{t('contact.whatsappDesc')}</p>
            <a href={whatsappUrl} class="btn-whatsapp text-lg px-8 py-3" target="_blank" rel="noopener noreferrer" data-track="whatsapp_click" data-track-label="Contact Page" data-track-category="conversion">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 448 512"><path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157z"/></svg>
              {t('contact.whatsappCta')}
            </a>
            <p class="text-surface-500 text-xs mt-4">📞 24/7 Support • Reply in Minutes</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  (function() {
    const form = document.getElementById('contact-form');
    const msg = document.getElementById('contact-success');
    const btn = document.getElementById('contact-btn');
    form?.addEventListener('submit', function(e) {
      e.preventDefault();
      if (btn) btn.disabled = true;
      setTimeout(function() {
        if (msg) msg.classList.remove('hidden');
        form?.reset();
        if (btn) btn.disabled = false;
      }, 1000);
    });
  })();
</script>
