---
import { getLangFromUrl, useTranslations } from '../i18n/ui';
import { getWhatsAppUrl, getWhatsAppTrialMsg } from '../i18n/whatsapp';
import WhatsAppIcon from './icons/WhatsAppIcon.astro';

interface Props {
  name: string;
  price: string;
  period: string;
  originalPrice?: string;
  savings?: string;
  features: string[];
  ctaLabel: string;
  trialLabel: string;
  featured?: boolean;
  popularLabel?: string;
}

const {
  name,
  price,
  period,
  originalPrice = '',
  savings = '',
  features,
  ctaLabel,
  trialLabel,
  featured = false,
  popularLabel = '',
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const isPromo = originalPrice !== '';

const buyMsg = (t('whatsapp.buyPlan') || 'Hi! I want the {plan} plan.').replace('{plan}', name);

---

<div class={`pricing-card reveal reveal-scale ${featured ? 'featured' : ''}`} data-reveal-delay={featured ? '200' : '0'}>
  {(isPromo || popularLabel) && (
    <div class="pricing-badges">
      {isPromo && (
        <span class="pricing-badge pricing-badge--sale">{savings}</span>
      )}
      {popularLabel && (
        <span class="pricing-badge">{popularLabel}</span>
      )}
    </div>
  )}
  <div>
    <h3 class="text-xl font-bold text-white">{name}</h3>
    <div class="mt-4 flex items-baseline gap-2 flex-wrap">
      {isPromo && (
        <span class="text-2xl text-surface-500 line-through">€{originalPrice}</span>
      )}
      <span class="text-5xl font-extrabold gradient-text-static" id={`price-${name.replace(/\s/g,'')}`}>€{price}</span>
      <span class="text-surface-400 text-sm">{period}</span>
    </div>

  </div>
  <ul class="space-y-3 flex-1">
    {features.map((f) => (
      <li class="checkmark">{f}</li>
    ))}
  </ul>
  <div class="flex flex-col gap-3 mt-2">
    <a
      href={getWhatsAppUrl(buyMsg)}
      class={`btn-whatsapp w-full text-base ${featured ? '!bg-gradient-to-r !from-brand-600 !to-brand-500 shadow-brand-500/30' : ''}`}
      target="_blank"
      rel="noopener noreferrer"
      data-track="whatsapp_click"
      data-track-label="Pricing Card"
      data-track-value={name}
      data-track-category="conversion"
    >
      <WhatsAppIcon class="h-5 w-5" />
      {ctaLabel}
    </a>
    <a
      href={getWhatsAppUrl(getWhatsAppTrialMsg(t))}
      class="text-center text-sm text-surface-400 hover:text-brand-400 transition-colors font-medium"
      target="_blank"
      rel="noopener noreferrer"
      data-track="whatsapp_click"
      data-track-label="Pricing Trial"
      data-track-value={name}
      data-track-category="conversion"
    >
      {trialLabel}
    </a>
  </div>
</div>
<style is:global>
/* ============================================
   PRICING CARDS
   ============================================ */

.pricing-card {
  background: rgba(15, 23, 42, 0.4);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(148, 163, 184, 0.08);
  border-radius: 1.5rem;
  padding: 2.25rem;
  display: flex;
  flex-direction: column;
  gap: 1.75rem;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
}
.pricing-card:hover {
  border-color: rgba(124, 58, 237, 0.3);
  box-shadow:
    0 0 40px rgba(124, 58, 237, 0.08),
    0 25px 50px rgba(0, 0, 0, 0.5);
  transform: translateY(-8px);
}

.pricing-card.featured {
  border: 1px solid rgba(124, 58, 237, 0.4);
  background: rgba(30, 20, 60, 0.5);
  box-shadow:
    0 0 50px rgba(124, 58, 237, 0.15),
    0 20px 40px rgba(0, 0, 0, 0.4);
  animation: border-glow 4s ease-in-out infinite;
}
.pricing-card.featured:hover {
  box-shadow:
    0 0 60px rgba(124, 58, 237, 0.25),
    0 30px 60px rgba(0, 0, 0, 0.6);
  transform: translateY(-10px);
}

.pricing-badge {
  background: linear-gradient(135deg, var(--color-brand-600), var(--color-brand-500));
  color: white;
  font-size: 0.75rem;
  font-weight: 700;
  padding: 0.375rem 1rem;
  border-radius: 9999px;
  letter-spacing: 0.05em;
  box-shadow: 0 2px 10px rgba(124, 58, 237, 0.4);
}

.pricing-badges {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.pricing-badge--sale {
  background: linear-gradient(135deg, #EF4444, #DC2626);
  color: white;
  box-shadow: 0 2px 10px rgba(239, 68, 68, 0.4);
}
</style>
