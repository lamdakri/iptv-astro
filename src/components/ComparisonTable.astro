---
import WhatsAppIcon from './icons/WhatsAppIcon.astro';

interface Props {
  eyebrow: string;
  title: string;
  subtitle: string;
  header: { feature: string; iptv: string; netflix: string; disney: string; cable: string; };
  rows: { label: string; iptv: string; netflix: string; disney: string; cable: string; highlight?: boolean; }[];
  ctaText: string;
  ctaUrl: string;
  note: string;
}

const { eyebrow, title, subtitle, header, rows, ctaText, ctaUrl, note } = Astro.props;
---

<section class="section section-alt">
  <div class="container-custom">
    <div class="text-center mb-14">
      <span class="section-eyebrow mx-auto justify-center">{eyebrow}</span>
      <h2 class="section-title">{title}</h2>
      <p class="section-subtitle mx-auto">{subtitle}</p>
    </div>

    <div class="max-w-4xl mx-auto overflow-x-auto reveal reveal-fade">
      <table class="w-full text-sm text-left">
        <thead>
          <tr class="border-b border-surface-800/30">
            <th class="py-4 pr-6 text-surface-400 font-medium w-1/5 min-w-[140px]">{header.feature}</th>
            <th class="py-4 pr-4 text-center w-1/5">
              <span class="gradient-text-static font-bold">{header.iptv}</span>
              <div class="text-xs text-surface-500 font-normal">→ Best Value</div>
            </th>
            <th class="py-4 px-4">{header.netflix}</th>
            <th class="py-4 px-4">{header.disney}</th>
            <th class="py-4 px-4">{header.cable}</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row, i) => (
            <tr class={"border-b border-surface-800/20 " + (row.highlight ? "bg-brand-900/10" : (i % 2 === 0 ? "bg-surface-900/20" : ""))}>
              <td class="py-3.5 pr-6 text-surface-200 font-medium">{row.label}</td>
              <td class="py-3.5 px-4 text-center text-brand-400 font-semibold">{row.iptv}</td>
              <td class="py-3.5 px-4">{row.netflix}</td>
              <td class="py-3.5 px-4">{row.disney}</td>
              <td class="py-3.5 px-4">{row.cable}</td>
            </tr>
          ))}
        </tbody>
      </table>

      {note && (
        <p class="text-xs text-surface-500 mt-4 text-center">{note}</p>
      )}
    </div>

    {ctaText && ctaUrl && (
      <div class="text-center mt-10 reveal">
        <a href={ctaUrl} class="btn-whatsapp text-lg px-8 py-3" target="_blank" rel="noopener noreferrer" data-track="whatsapp_click" data-track-label="Comparison CTA" data-track-category="conversion">
          <WhatsAppIcon class="h-5 w-5" />
          {ctaText}
        </a>
      </div>
    )}
  </div>
</section>
<style>
  th { text-align: center; }
  th:first-child { text-align: left; }
  td { text-align: center; color: var(--color-surface-300); }
  td:first-child { text-align: left; }
  @media (max-width: 640px) {
    th:not(:first-child), td:not(:first-child) { font-size: 0.75rem; padding-left: 0.25rem; padding-right: 0.25rem; }
  }
</style>
