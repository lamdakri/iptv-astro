---
interface Step {
  number: string;
  icon: string;
  title: string;
  description: string;
}

interface Props {
  eyebrow: string;
  title: string;
  subtitle: string;
  steps: Step[];
  ctaText: string;
  ctaUrl: string;
}

const { eyebrow, title, subtitle, steps, ctaText, ctaUrl } = Astro.props;
---

<section class="section section-alt">
  <div class="container-custom">
    <div class="text-center mb-14">
      <span class="section-eyebrow mx-auto justify-center">{eyebrow}</span>
      <h2 class="section-title text-center">{title}</h2>
      <p class="section-subtitle mx-auto">{subtitle}</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto relative">
      <div class="hidden md:block absolute top-14 left-[18%] right-[18%] h-0.5 bg-gradient-to-r from-brand-500/40 via-cyan-400/40 to-brand-500/40"></div>
      {steps.map((step, i) => (
        <div class="relative text-center reveal reveal-fade" data-reveal-delay={String(i * 150)}>
          <div class="relative z-10 mx-auto mb-6 w-16 h-16 rounded-full flex items-center justify-center text-2xl font-extrabold gradient-text-static border-2 border-brand-500/30 bg-surface-900/80">
            <span class="step-number">{step.number}</span>
          </div>
          <div class="text-4xl mb-4">{step.icon}</div>
          <h3 class="text-xl font-bold text-white mb-3">{step.title}</h3>
          <p class="text-surface-400 leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
    {ctaText && ctaUrl && (
      <div class="text-center mt-12 reveal">
        <a href={ctaUrl} class="btn-whatsapp text-lg px-8 py-3" target="_blank" rel="noopener noreferrer" data-track="whatsapp_click" data-track-label="Steps CTA" data-track-category="conversion">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 448 512"><path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157z"/></svg>
          {ctaText}
        </a>
      </div>
    )}
  </div>
</section>

<style>
  .step-number { transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1); }
  .reveal.visible .step-number {
    animation: step-pop 0.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }
  @keyframes step-pop {
    0% { transform: scale(0.3); opacity: 0; }
    60% { transform: scale(1.2); }
    100% { transform: scale(1); opacity: 1; }
  }
</style>
