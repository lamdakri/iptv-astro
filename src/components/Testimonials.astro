---
interface Testimonial {
  name: string;
  role: string;
  text: string;
  rating?: number;
}

interface Props {
  title: string;
  subtitle?: string;
  eyebrow?: string;
  testimonials: Testimonial[];
}

const { title, subtitle, eyebrow, testimonials } = Astro.props;
---

<section class="section">
  <div class="section-divider"></div>
  <div class="container-custom">
    <div class="text-center mb-14">
      <span class="section-eyebrow">{eyebrow}</span>
      <h2 class="section-title">{title}</h2>
      {subtitle && <p class="section-subtitle mx-auto">{subtitle}</p>}
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map((t, i) => (
        <div class="testimonial-card reveal reveal-scale" data-reveal-delay={String(i * 150)}>
          {t.rating && (
            <div class="stars">
              {Array.from({ length: t.rating }).map(() => <span>★</span>)}
            </div>
          )}
          <p class="text-surface-300 italic leading-relaxed text-sm">"{t.text}"</p>
          <div class="mt-auto pt-3 border-t border-surface-800/30">
            <p class="text-white font-semibold text-sm">{t.name}</p>
            <p class="text-surface-500 text-xs">{t.role}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
<style is:global>
/* ============================================
   TESTIMONIAL CARDS
   ============================================ */

.testimonial-card {
  background: rgba(15, 23, 42, 0.4);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(148, 163, 184, 0.06);
  border-radius: 1.25rem;
  padding: 2rem;
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
  transition: all 0.3s ease;
  position: relative;
}
.testimonial-card:hover {
  border-color: rgba(124, 58, 237, 0.15);
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
  transform: translateY(-3px);
}
.testimonial-card::before {
  content: '"';
  position: absolute;
  top: 0.5rem;
  right: 1.5rem;
  font-size: 4rem;
  line-height: 1;
  color: rgba(124, 58, 237, 0.15);
  font-family: Georgia, serif;
  pointer-events: none;
}
[dir="rtl"] .testimonial-card::before {
  right: auto;
  left: 1.5rem;
}
</style>
