---
import { getLangFromUrl, useTranslations } from '../i18n/ui';

const t = useTranslations(getLangFromUrl(Astro.url));

interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
const siteUrl = Astro.site?.href || 'https://iptv4kworld.com';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: item.label,
    ...(item.href && { item: new URL(item.href, siteUrl).href }),
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} is:inline></script>
<nav class="breadcrumb" aria-label={t('a11y.breadcrumb')}>
  {items.map((item, i) => (
    <>
      {i > 0 && <span class="separator">/</span>}
      {item.href ? (
        <a href={item.href}>{item.label}</a>
      ) : (
        <span class="text-surface-200">{item.label}</span>
      )}
    </>
  ))}
</nav>
<style is:global>
/* ============================================
   BREADCRUMB
   ============================================ */

.breadcrumb {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.875rem;
  color: var(--color-surface-400);
  padding-top: 1.5rem;
  padding-bottom: 1rem;
}
.breadcrumb a {
  color: var(--color-surface-400);
  transition: color 0.2s;
}
.breadcrumb a:hover {
  color: var(--color-brand-400);
}
.breadcrumb .separator {
  color: var(--color-surface-600);
}
</style>
