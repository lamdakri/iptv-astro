---
import { useTranslations, LANGUAGES } from "../../i18n/ui";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PricingCard from "../../components/PricingCard.astro";
import SavingsComparison from "../../components/SavingsComparison.astro";
import FAQ from "../../components/FAQ.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import SchemaMarkup from "../../components/SchemaMarkup.astro";
import PaymentIcons from "../../components/PaymentIcons.astro";
import PayPalBadge from "../../components/PayPalBadge.astro";
import { getWhatsAppUrl, getWhatsAppTrialMsg } from "../../i18n/whatsapp";
import { getAggregateRating } from "../../data/testimonials";
import prices from "../../data/prices.json";

export function getStaticPaths() {
  return Object.keys(LANGUAGES).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang);

const faqItems = [
  { question: t("faq.q1"), answer: t("faq.a1") },
  { question: t("faq.q2"), answer: t("faq.a2") },
  { question: t("faq.q4"), answer: t("faq.a4") },
  { question: t("faq.q5"), answer: t("faq.a5") },
  { question: t("faq.q6"), answer: t("faq.a6") },
];

const pricingFeatures = [
  t("pricing.feature.channels"),
  t("pricing.feature.quality"),
  t("pricing.feature.vod"),
  t("pricing.feature.devices"),
  t("pricing.feature.antifreeze"),
  t("pricing.feature.support"),
  t("pricing.feature.instant"),
];

const pageTitle = t("pricing.title") + " | " + t("site.name");
---

<BaseLayout
  title={pageTitle}
  description={t("pricing.subtitle")}
  keywords={t("seo.keywords")}
  schema={{
    "@context": "https://schema.org",
    "@type": "Product",
    name: "IPTV 4K World",
    description: t("pricing.subtitle"),
    offers: {
      "@type": "AggregateOffer",
      offerCount: 3,
      lowPrice: prices.threeMonths,
      highPrice: prices.oneYear,
      priceCurrency: prices.currency,
      availability: "https://schema.org/InStock",
    },
    aggregateRating: getAggregateRating(),
  }}
>
  <SchemaMarkup type="product" data={{ lowPrice: prices.threeMonths, highPrice: prices.oneYear, currency: prices.currency }} />

  <section class="pt-32 pb-20">
    <div class="container-custom">
      <Breadcrumb
        items={[
          { label: t("breadcrumb.home"), href: "/" + lang + "/" },
          { label: t("pricing.title") },
        ]}
      />

      <div class="text-center mb-12 reveal">
        <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4">{t("pricing.title")}</h1>
        <p class="text-surface-400 text-lg max-w-2xl mx-auto">{t("pricing.subtitle")}</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto reveal">
        <PricingCard
          name={t("pricing.3months")}
          price={t("pricing.3months.price")}
          period={t("pricing.period.3months")}
          features={pricingFeatures}
          ctaLabel={t("pricing.cta")}
          trialLabel={t("pricing.trial")}
        />
        <PricingCard
          name={t("pricing.6months")}
          price={t("pricing.6months.price")}
          period={t("pricing.period.6months")}
          features={pricingFeatures}
          ctaLabel={t("pricing.cta")}
          trialLabel={t("pricing.trial")}
          popularLabel={t("pricing.popular")}
        />
        <PricingCard
          name={t("pricing.1year")}
          price={t("pricing.1year.price")}
          period={t("pricing.period.1year")}
          originalPrice={t("pricing.originalPrice")}
          savings={t("pricing.savings")}
          features={pricingFeatures}
          ctaLabel={t("pricing.cta")}
          trialLabel={t("pricing.trial")}
          featured={true}
          popularLabel={t("pricing.bestValue")}
        />
      </div>

      <!-- Payment methods -->
      <div class="text-center mt-8 reveal">
        <div
          class="inline-flex items-center gap-3 px-5 py-3 rounded-xl bg-surface-900/50 border border-surface-800/30"
        >
          <PaymentIcons />
          <span class="text-surface-300 text-sm font-medium">{t("payment.methods")}</span>
          <span class="w-1 h-1 rounded-full bg-green-500"></span>
          <span class="text-surface-500 text-xs">{t("payment.trust")}</span>
        </div>
      </div>

      <!-- CTA -->
      <div class="text-center mt-16 reveal">
        <a
          href={getWhatsAppUrl(getWhatsAppTrialMsg(t))}
          class="btn-whatsapp text-xl px-12 py-5"
          target="_blank"
          rel="noopener noreferrer"
        >
          {t("cta.trial")}
        </a>
        <div class="mt-3">
          <PayPalBadge />
        </div>
      </div>
    </div>
  </section>

  <SavingsComparison
    title={t("savings.title")}
    subtitle={t("savings.subtitle")}
    headerPlan={t("savings.headerPlan")}
    headerMonthly={t("savings.headerMonthly")}
    headerOurPrice={t("savings.headerOurPrice")}
    headerSavings={t("savings.headerSavings")}
    monthlyRate={t("savings.monthlyRate")}
    eyebrow={t("savings.eyebrow")}
    bestDeal={t("savings.bestDeal")}
    ctaText={t("savings.ctaText")}
    ctaButton={t("savings.ctaButton")}
    rows={[
      {
        duration: t("pricing.3months"),
        monthlyCost: t("savings.3months.monthlyCost"),
        ourPrice: prices.symbol + t("pricing.3months.price"),
        savings: t("savings.3months.savings"),
        savingsPct: t("savings.3months.pct"),
      },
      {
        duration: t("pricing.6months"),
        monthlyCost: t("savings.6months.monthlyCost"),
        ourPrice: prices.symbol + t("pricing.6months.price"),
        savings: t("savings.6months.savings"),
        savingsPct: t("savings.6months.pct"),
      },
      {
        duration: t("pricing.1year"),
        monthlyCost: t("savings.1year.monthlyCost"),
        ourPrice: prices.symbol + t("pricing.1year.price"),
        savings: t("savings.1year.savings"),
        savingsPct: t("savings.1year.pct"),
        featured: true,
      },
    ]}
  />

  <FAQ title={t("faq.title")} subtitle={t("faq.subtitle")} items={faqItems} />
</BaseLayout>
