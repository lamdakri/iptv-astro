---
import { getWhatsAppUrl, getWhatsAppTrialMsg } from '../i18n/whatsapp';
import { getLangFromUrl, useTranslations } from '../i18n/ui';
import PayPalBadge from './PayPalBadge.astro';
import WhatsAppIcon from './icons/WhatsAppIcon.astro';

interface Sport {
  icon: string;
  name: string;
  tagline: string;
  color: string;
}

interface Props {
  title: string;
  subtitle: string;
  eyebrow: string;
  sports: Sport[];
  ctaText: string;
  ctaButton: string;
}

const { title, subtitle, eyebrow, sports, ctaText, ctaButton } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="section section-alt">
  <div class="section-divider"></div>
  <div class="container-custom">
    <div class="text-center mb-14">
      <span class="section-eyebrow justify-center">{eyebrow}</span>
      <h2 class="section-title">{title}</h2>
      <p class="section-subtitle mx-auto">{subtitle}</p>
    </div>

    <!-- Sport cards grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4 max-w-5xl mx-auto">
      {
        sports.map((s, i) => (
          <div
            class="glass-card p-5 flex flex-col items-center text-center gap-3 group cursor-default reveal reveal-scale"
            data-reveal-delay={String(i * 100)}
          >
            <span class="text-4xl transition-transform duration-300 group-hover:scale-125">
              {s.icon}
            </span>
            <h3 class={`text-white font-bold text-sm ${s.color}`}>{s.name}</h3>
            <p class="text-surface-500 text-xs leading-relaxed">{s.tagline}</p>
          </div>
        ))
      }
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-12 reveal">
      <p class="text-surface-400 text-sm mb-4">{ctaText}</p>
      <a
        href={getWhatsAppUrl(getWhatsAppTrialMsg(t))}
        class="btn-whatsapp text-lg px-10 py-4"
        target="_blank"
        rel="noopener noreferrer"
        data-track="whatsapp_click"
        data-track-label="Sports CTA"
        data-track-category="conversion"
      >
        <WhatsAppIcon class="h-5 w-5" />
        {ctaButton}
      </a>
      <div class="mt-3">
        <PayPalBadge />
      </div>
    </div>
  </div>
</section>
