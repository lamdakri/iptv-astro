---
import { getLangFromUrl, useTranslations } from '../i18n/ui';
import { getWhatsAppUrl, getWhatsAppTrialMsg } from '../i18n/whatsapp';
import WhatsAppIcon from './icons/WhatsAppIcon.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<a
  id="floating-wa-btn"
  data-track="whatsapp_click"
  data-track-label="Floating Button"
  data-track-category="conversion"
  href={getWhatsAppUrl(getWhatsAppTrialMsg(t))}
  target="_blank"
  rel="noopener noreferrer"
  class="floating-whatsapp"
  aria-label={t('cta.trial')}
>
  <WhatsAppIcon class="h-5 w-5" variant="full" />
  <span class="hidden sm:inline font-medium text-sm">{t('cta.trial.short')}</span>
</a>

<script>
  (function() {
    const btn = document.getElementById('floating-wa-btn');
    if (!btn) return;
    let timeout;
    function checkFooter() {
      const scrollBottom = window.innerHeight + window.scrollY;
      const docHeight = document.documentElement.scrollHeight;
      const nearBottom = docHeight - scrollBottom < 250;
      if (nearBottom) {
        btn.classList.add('floating-whatsapp--hidden');
      } else {
        btn.classList.remove('floating-whatsapp--hidden');
      }
    }
    window.addEventListener('scroll', function() {
      clearTimeout(timeout);
      timeout = setTimeout(checkFooter, 50);
    }, { passive: true });
    checkFooter();
  })();
</script>
